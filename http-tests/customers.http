@baseUrl = http://localhost:8080
@customerId = 1
@token = REPLACE_WITH_JWT_TOKEN_FROM_2FA_VERIFY

### Create customer
POST {{baseUrl}}/api/v1/customers
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Acme Corp",
  "email": "acme@example.com",
  "phone": "+15551112222"
}

### List customers
GET {{baseUrl}}/api/v1/customers
Authorization: Bearer {{token}}

### Get customer by id
GET {{baseUrl}}/api/v1/customers/{{customerId}}
Authorization: Bearer {{token}}

### Update customer
PUT {{baseUrl}}/api/v1/customers/{{customerId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Acme Corporation",
  "email": "acme.updated@example.com",
  "phone": "+15553334444"
}

### Delete customer
DELETE {{baseUrl}}/api/v1/customers/{{customerId}}
Authorization: Bearer {{token}}
