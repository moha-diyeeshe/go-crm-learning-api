@baseUrl = http://localhost:8080
@userId = 1

### Create user
POST {{baseUrl}}/api/v1/users
Content-Type: application/json

{
  "name": "Alice Doe",
  "email": "alice@example.com",
  "phone": "+15550001111",
  "password": "Pass@1234"
}

### List users
GET {{baseUrl}}/api/v1/users

### Get user by id
GET {{baseUrl}}/api/v1/users/{{userId}}

### Update user
PUT {{baseUrl}}/api/v1/users/{{userId}}
Content-Type: application/json

{
  "name": "Alice Updated",
  "email": "alice.updated@example.com",
  "phone": "+15550002222"
}

### Login with password (step 1 of 2FA flow)
POST {{baseUrl}}/api/v1/users/{{userId}}/login
Content-Type: application/json

{
  "password": "Pass@1234"
}

### Send TOTP code (demo logs code in server terminal)
POST {{baseUrl}}/api/v1/users/{{userId}}/2fa/send

### Verify TOTP code (replace with code from logs)
POST {{baseUrl}}/api/v1/users/{{userId}}/2fa/verify
Content-Type: application/json

{
  "code": "123456"
}

### Change password
POST {{baseUrl}}/api/v1/users/{{userId}}/password/change
Content-Type: application/json

{
  "old_password": "Pass@1234",
  "new_password": "Pass@9999"
}

### Delete user
DELETE {{baseUrl}}/api/v1/users/{{userId}}
