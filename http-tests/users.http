@baseUrl = http://localhost:8080
@userId = 1
@accessToken = REPLACE_WITH_ACCESS_TOKEN
@refreshToken = REPLACE_WITH_REFRESH_TOKEN

### Create user
POST {{baseUrl}}/api/v1/users
Content-Type: application/json

{
  "name": "Mohamed Ali",
  "email": "mohamedmuhudin17@gmail.com",
  "phone": "+15550001111",
  "password": "Pass@1234"
}

### List users
GET {{baseUrl}}/api/v1/users
Authorization: Bearer {{accessToken}}

### Get user by id
GET {{baseUrl}}/api/v1/users/{{userId}}
Authorization: Bearer {{accessToken}}

### Update user
PUT {{baseUrl}}/api/v1/users/{{userId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Alice Updated",
  "email": "alice.updated@example.com",
  "phone": "+15550002222"
}

### Login with email + password (returns access_token + refresh_token)
POST {{baseUrl}}/api/v1/users/login
Content-Type: application/json

{
  "email": "mohamedmuhudin17@gmail.com",
  "password": "Pass@1234"
}

### Refresh tokens (returns a rotated access_token + refresh_token)
POST {{baseUrl}}/api/v1/users/token/refresh
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Legacy flow: Send TOTP code (demo logs code in server terminal)
POST {{baseUrl}}/api/v1/users/{{userId}}/2fa/send

### Legacy flow: Verify TOTP code (replace with code from logs)
POST {{baseUrl}}/api/v1/users/{{userId}}/2fa/verify
Content-Type: application/json

{
  "code": "123456"
}

### Copy access_token and refresh_token into @accessToken/@refreshToken variables above

### Change password
POST {{baseUrl}}/api/v1/users/{{userId}}/password/change
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "old_password": "Pass@1234",
  "new_password": "Pass@9999"
}

### Delete user
DELETE {{baseUrl}}/api/v1/users/{{userId}}
Authorization: Bearer {{accessToken}}
